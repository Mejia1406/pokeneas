<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pokeneas – <%= nombre %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,400&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/pokenea.css" />
</head>
<body>

  <div>
    <div class="card">

      <div class="card__header">
        <span class="card__header-title">✦ Pokeneas de Antioquia</span>
        <span class="card__id-badge">#<%= id.toString().padStart(3, '0') %></span>
      </div>

      <div class="card__image-wrap">
        <span class="card__pokenea-number">No. <%= id.toString().padStart(3, '0') %></span>
        <img
          class="card__image"
          src="<%= imagen %>"
          alt="Imagen de <%= nombre %>"
          onerror="this.src='/images/placeholder.png'; this.onerror=null;"
        />
      </div>

      <h1 class="card__name"><%= nombre %></h1>

      <div class="card__quote-wrap">
        <span class="card__quote-mark">"</span>
        <p class="card__quote"><%= frase %></p>
      </div>

      <div class="card__footer">
        <div class="card__container-info">
          <span class="card__container-label">Docker Container</span>
          <span class="card__container-id"><%= contenedor %></span>
        </div>
        <a href="/pokenea" class="card__refresh-btn">↻ Otro Pokenea</a>
      </div>

    </div>

    <nav class="nav-links">
      <a href="/pokenea">Vista Visual</a>
      <a href="/api/pokenea">API JSON</a>
    </nav>
  </div>

</body>
</html>
